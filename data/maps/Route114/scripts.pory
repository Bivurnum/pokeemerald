script Route114_EventScript_WallyTrigger9 {
	lock
	setvar (VAR_0x8008, 9)
	goto (Route114_EventScript_WallyEvent)
	end
}

script Route114_EventScript_WallyTrigger10 {
	lock
	setvar (VAR_0x8008, 10)
	goto (Route114_EventScript_WallyEvent)
	end
}

script Route114_EventScript_WallyEvent {
	playse (SE_PIN)
	applymovement (LOCALID_WALLY, Common_Movement_ExclamationMark)
	waitmovement (0)
	if (var(VAR_0x8008) < 4) {
		applymovement (LOCALID_WALLY, Common_Movement_FaceUp)
	}
	elif (var(VAR_0x8008) > 3 && var(VAR_0x8008) < 9) {
		applymovement (LOCALID_WALLY, Common_Movement_FaceRight)
	}
	else {
		applymovement (LOCALID_WALLY, Common_Movement_FaceDown)
	}
	waitmovement (0)
	delay (56)
	msgbox (Route114_Text_OhHey, MSGBOX_AUTOCLOSE)
	applymovement (LOCALID_WALLY, Common_Movement_FaceRight)
	switch (var(VAR_0x8008)) {
		case 1:
			applymovement (OBJ_EVENT_ID_PLAYER, Route114_Movement_WalkToWally1)
		case 2:
			applymovement (OBJ_EVENT_ID_PLAYER, Route114_Movement_WalkToWally2)
		case 3:
			applymovement (OBJ_EVENT_ID_PLAYER, Route114_Movement_WalkToWally3)
		case 4:
			applymovement (OBJ_EVENT_ID_PLAYER, Route114_Movement_WalkToWally4)
		case 5:
			applymovement (OBJ_EVENT_ID_PLAYER, Route114_Movement_WalkToWally5)
		case 6:
			applymovement (OBJ_EVENT_ID_PLAYER, Route114_Movement_WalkToWally6)
		case 7:
			applymovement (OBJ_EVENT_ID_PLAYER, Route114_Movement_WalkToWally7)
		case 8:
			applymovement (OBJ_EVENT_ID_PLAYER, Route114_Movement_WalkToWally8)
		case 9:
			applymovement (OBJ_EVENT_ID_PLAYER, Route114_Movement_WalkToWally9)
		case 10:
			applymovement (OBJ_EVENT_ID_PLAYER, Route114_Movement_WalkToWally10)
	}
	waitmovement (0)
	applymovement (LOCALID_WALLY, Common_Movement_FaceRight)
	waitmovement (0)
	msgbox (Route114_Text_SomeoneRidingThisWay, MSGBOX_AUTOCLOSE)
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterRight)
	waitmovement (0)
	addobject (LOCALID_RIVAL1BIKE)
	playse (SE_BIKE_BELL)
	applymovement (OBJ_EVENT_ID_PLAYER, Route114_Movement_WatchRivalBike)
	applymovement (LOCALID_WALLY, Route114_Movement_WatchRivalBike)
	applymovement (LOCALID_RIVAL1BIKE, Route114_Movement_Rival1BikesAround)
	waitmovement (0)
	removeobject (LOCALID_RIVAL1BIKE)
	addobject (LOCALID_RIVAL1)
	rival1talk (Route114_Text_SpencerLetsBattle,
				Route114_Text_BrenLetsBattle,
				Route114_Text_KyleLetsBattle)
	closemessage
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_FaceLeft)
	applymovement (LOCALID_WALLY, Common_Movement_BeginTalkRight)
	waitmovement (0)
	msgbox (Route114_Text_PleaseLetMeAssist)
	delay (10)
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_FaceDown)
	applymovement (LOCALID_WALLY, Common_Movement_FaceDown)
	applymovement (LOCALID_RIVAL1, Common_Movement_BeginTalkUp)
	waitmovement (0)
	rival1talk (Route114_Text_SpencerPickYourPokemon,
				Route114_Text_BrenPickYourPokemon,
				Route114_Text_KylePickYourPokemon)
				closemessage
	

	multi_2_vs_1 ()



	playse (SE_BIKE_BELL)
	applymovement (LOCALID_RIVAL1BIKE, Route114_Movement_Rival1BikesAway)
	waitmovement (0)
	delay (16)
	applymovement (LOCALID_WALLY, Common_Movement_WalkInPlaceFasterRight)
	waitmovement (0)
	msgbox (Route114_Text_HeWavedAndSmiled, MSGBOX_AUTOCLOSE)
	applymovement (OBJ_EVENT_ID_PLAYER, Route114_Movement_WatchWallyLeave)
	applymovement (LOCALID_WALLY, Route114_Movement_WallyLeave)
	waitmovement (0)
	removeobject (LOCALID_WALLY)
	setvar (VAR_METEOR_FALLS_STATE, 1)
	setvar (VAR_0x8008, 0)
	setflag (FLAG_HIDE_ROUTE_113_RIVAL1)
	release
	end
}

movement Route114_Movement_WalkToWally1 {
	walk_down * 5
	walk_left
}

movement Route114_Movement_WalkToWally2 {
	walk_down * 4
	walk_left
}

movement Route114_Movement_WalkToWally3 {
	walk_down * 3
	walk_left
}

movement Route114_Movement_WalkToWally4 {
	walk_down * 2
	walk_left * 2
}

movement Route114_Movement_WalkToWally5 {
	walk_left * 2
	walk_down
	walk_left
}

movement Route114_Movement_WalkToWally6 {
	walk_left * 3
}

movement Route114_Movement_WalkToWally7 {
	walk_left * 2
	walk_up
	walk_left
}

movement Route114_Movement_WalkToWally8 {
	walk_up * 2
	walk_left * 2
}

movement Route114_Movement_WalkToWally9 {
	walk_up * 3
	walk_left
}

movement Route114_Movement_WalkToWally10 {
	walk_up * 3
	walk_in_place_left
}

movement Route114_Movement_Rival1BikesAround {
	walk_fast_left * 11
	walk_fast_down * 4
	walk_fast_right * 5
	walk_fast_up * 4
	walk_fast_left * 5
	walk_fast_down * 4
	walk_fast_right * 3
	walk_fast_up
	delay_16
}

movement Route114_Movement_WatchRivalBike {
	delay_8 * 7
	face_up
	delay_8 * 4
	face_left
	delay_8 * 4
	face_down
	delay_8 * 5
	face_right
	delay_8 * 4
	face_up
	delay_8 * 5
	face_left
	delay_8 * 4
	face_down
}

movement Route114_Movement_Rival1BikesAway {
	walk_fast_left * 7
}

movement Route114_Movement_WatchWallyLeave {
	delay_16
	face_up
	delay_16 * 3
	face_right
}

movement Route114_Movement_WallyLeave {
	walk_up
	walk_right * 9
}

text Route114_Text_OhHey {
	format ("Oh, hey {PLAYER}!")
}

text Route114_Text_SomeoneRidingThisWay {
	format ("WALLY: I didn't think I'd run into you so soon.\p"
		"Don't worry. I'm not here to battle you.\p"
		"RALTS and I came out here to train.\n"
		"It's been going pretty well!\p"
		"Oh!\n"
		"I think I see someone riding their bike this way!")
}

text Route114_Text_HeWavedAndSmiled {
	format ("WALLY: That guy just waved and smiled at us!\n"
		"He seems like a strong, confident trainer.\p"
		"Oh, he's your friend?\n"
		"Wow! Between this cool guy on the bike and the boy who helped me battle in MAUVILLE, you have some pretty awesome companions.\p"
		"The three of you are so strong…\p"
		"But someday I'm going to show you just how strong I can get!\p"
		"You just wait!\n"
		"Until we meet again!")
}

text Route114_Text_SpencerLetsBattle {
	format ("SPENCER: I got a new POKéMON and I'm raring to try it out.\p"
		"C'mon!\n"
		"Let's have a battle!\n"
		"Give me all you got!")
}

text Route114_Text_BrenLetsBattle {
	format ("BREN: I got a new POKéMON and I'm raring to try it out.\p"
		"C'mon!\n"
		"Let's have a battle!\n"
		"Give me all you got!")
}

text Route114_Text_KyleLetsBattle {
	format ("KYLE: I got a new POKéMON and I'm raring to try it out.\p"
		"C'mon!\n"
		"Let's have a battle!\n"
		"Give me all you got!")
}

text Route114_Text_PleaseLetMeAssist {
	format ("WALLY: {PLAYER}, you've been a help to me so many times now.\N"
		"I want to assist you for once.\p"
		"Please let me battle alongside you!")
}

text Route114_Text_SpencerPickYourPokemon {
	format ("SPENCER: That's fine by me!\n"
		"I'm feeling so good right now, I can probably beat you both easily!\p"
		"Pick your POKéMON and prepare for defeat!")
}

text Route114_Text_BrenPickYourPokemon {
	format ("BREN: That's fine by me!\n"
		"I'm feeling so good right now, I can probably beat you both easily!\p"
		"Pick your POKéMON and prepare for defeat!")
}

text Route114_Text_KylePickYourPokemon {
	format ("KYLE: That's fine by me!\n"
		"I'm feeling so good right now, I can probably beat you both easily!\p"
		"Pick your POKéMON and prepare for defeat!")
}

raw `
Route114_EventScript_Man::
	lock
	faceplayer
	dotimebasedevents
	goto_if_set FLAG_DAILY_ROUTE_114_RECEIVED_BERRY, Route114_EventScript_ReceivedBerry
	msgbox Route114_Text_LoveUsingBerryCrushShareBerry, MSGBOX_DEFAULT
	random NUM_ROUTE_114_MAN_BERRIES
	addvar VAR_RESULT, NUM_ROUTE_114_MAN_BERRIES_SKIPPED
	addvar VAR_RESULT, FIRST_BERRY_INDEX
	giveitem VAR_RESULT
	goto_if_eq VAR_RESULT, FALSE, Common_EventScript_ShowBagIsFull
	setflag FLAG_DAILY_ROUTE_114_RECEIVED_BERRY
	msgbox Route114_Text_TryBerryCrushWithFriends, MSGBOX_DEFAULT
	release
	end

Route114_EventScript_ReceivedBerry::
	msgbox Route114_Text_FunToThinkAboutBerries, MSGBOX_DEFAULT
	release
	end

Route114_EventScript_RoarGentleman::
	lock
	faceplayer
	goto_if_set FLAG_RECEIVED_TM_ROAR, Route114_EventScript_ReceivedRoar
	msgbox Route114_Text_AllMyMonDoesIsRoarTakeThis, MSGBOX_DEFAULT
	giveitem ITEM_TM_ROAR
	goto_if_eq VAR_RESULT, FALSE, Common_EventScript_ShowBagIsFull
	setflag FLAG_RECEIVED_TM_ROAR
	msgbox Route114_Text_ExplainRoar, MSGBOX_DEFAULT
	release
	end

Route114_EventScript_ReceivedRoar::
	msgbox Route114_Text_ExplainRoar, MSGBOX_DEFAULT
	release
	end

Route114_EventScript_Poochyena::
	lock
	faceplayer
	waitse
	playmoncry SPECIES_POOCHYENA, CRY_MODE_ENCOUNTER
	msgbox Route114_Text_Poochyena, MSGBOX_DEFAULT
	waitmoncry
	release
	end

Route114_EventScript_MeteorFallsSign::
	msgbox Route114_Text_MeteorFallsSign, MSGBOX_SIGN
	end

Route114_EventScript_FossilManiacsHouseSign::
	msgbox Route114_Text_FossilManiacsHouseSign, MSGBOX_SIGN
	end

Route114_EventScript_LanettesHouseSign::
	msgbox Route114_Text_LanettesHouse, MSGBOX_SIGN
	end

Route114_EventScript_Lenny::
	trainerbattle_single TRAINER_LENNY, Route114_Text_LennyIntro, Route114_Text_LennyDefeat
	msgbox Route114_Text_LennyPostBattle, MSGBOX_AUTOCLOSE
	end

Route114_EventScript_Lucas::
	trainerbattle_single TRAINER_LUCAS_1, Route114_Text_LucasIntro, Route114_Text_LucasDefeat
	msgbox Route114_Text_LucasPostBattle, MSGBOX_AUTOCLOSE
	end

Route114_EventScript_Shane::
	trainerbattle_single TRAINER_SHANE, Route114_Text_ShaneIntro, Route114_Text_ShaneDefeat
	msgbox Route114_Text_ShanePostBattle, MSGBOX_AUTOCLOSE
	end

Route114_EventScript_Nancy::
	trainerbattle_single TRAINER_NANCY, Route114_Text_NancyIntro, Route114_Text_NancyDefeat
	msgbox Route114_Text_NancyPostBattle, MSGBOX_AUTOCLOSE
	end

Route114_EventScript_Steve::
	trainerbattle_single TRAINER_STEVE_1, Route114_Text_SteveIntro, Route114_Text_SteveDefeat, Route114_EventScript_RegisterSteve
	specialvar VAR_RESULT, ShouldTryRematchBattle
	goto_if_eq VAR_RESULT, TRUE, Route114_EventScript_RematchSteve
	msgbox Route114_Text_StevePostBattle, MSGBOX_DEFAULT
	release
	end

Route114_EventScript_RegisterSteve::
	special PlayerFaceTrainerAfterBattle
	waitmovement 0
	msgbox Route114_Text_SteveRegister, MSGBOX_DEFAULT
	register_matchcall TRAINER_STEVE_1
	release
	end

Route114_EventScript_RematchSteve::
	trainerbattle_rematch TRAINER_STEVE_1, Route114_Text_SteveRematchIntro, Route114_Text_SteveRematchDefeat
	msgbox Route114_Text_StevePostRematch, MSGBOX_AUTOCLOSE
	end

Route114_EventScript_Bernie::
	trainerbattle_single TRAINER_BERNIE_1, Route114_Text_BernieIntro, Route114_Text_BernieDefeat, Route114_EventScript_RegisterBernie
	specialvar VAR_RESULT, ShouldTryRematchBattle
	goto_if_eq VAR_RESULT, TRUE, Route114_EventScript_RematchBernie
	msgbox Route114_Text_BerniePostBattle, MSGBOX_DEFAULT
	release
	end

Route114_EventScript_RegisterBernie::
	special PlayerFaceTrainerAfterBattle
	waitmovement 0
	msgbox Route114_Text_BernieRegister, MSGBOX_DEFAULT
	register_matchcall TRAINER_BERNIE_1
	release
	end

Route114_EventScript_RematchBernie::
	trainerbattle_rematch TRAINER_BERNIE_1, Route114_Text_BernieRematchIntro, Route114_Text_BernieRematchDefeat
	msgbox Route114_Text_BerniePostRematch, MSGBOX_AUTOCLOSE
	end

Route114_EventScript_Claude::
	trainerbattle_single TRAINER_CLAUDE, Route114_Text_ClaudeIntro, Route114_Text_ClaudeDefeat
	msgbox Route114_Text_ClaudePostBattle, MSGBOX_AUTOCLOSE
	end

