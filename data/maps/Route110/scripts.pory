const LOCALID_CHALLENGE_BIKER = 21
const LOCALID_RIVAL2 = 28
const LOCALID_BIRCH = 35
const LOCALID_RIVAL1 = 36
const LOCALID_RIVAL1FINDER = 37

raw `
.set LOCALID_CHALLENGE_BIKER, 21
.set LOCALID_RIVAL2, 28
.set LOCALID_BIRCH, 35
.set LOCALID_RIVAL1, 36
.set LOCALID_RIVAL1FINDER, 37
`

mapscripts Route110_MapScripts {
	MAP_SCRIPT_ON_RESUME {
		special (UpdateCyclingRoadState)
	}
	MAP_SCRIPT_ON_TRANSITION {
		call (Common_EventScript_SetupRivalGfxId)
		call_if_eq (VAR_CYCLING_CHALLENGE_STATE, 1, Route110_EventScript_SaveCyclingMusic)
		call_if_eq (VAR_ROUTE110_STATE, 0, Route110_EventScript_SetUpItemfinderScene)
		call_if_ge (VAR_ROUTE110_STATE, 1, Route110_EventScript_SetUpPostItemfinderRivals)
	}
	MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_CYCLING_CHALLENGE_STATE, 1: Route110_EventScript_BeginCylcingRoadChallenge
	]
}

script Route110_EventScript_SaveCyclingMusic {
	savebgm (MUS_CYCLING)
	return
}

script Route110_EventScript_SetUpItemfinderScene {
	setobjectxyperm (LOCALID_RIVAL1, 33, 62)
	setobjectxyperm (LOCALID_RIVAL2, 34, 54)
	setobjectmovementtype (LOCALID_RIVAL2, MOVEMENT_TYPE_FACE_LEFT_AND_RIGHT)
}

script Route110_EventScript_SetUpPostItemfinderRivals {
	setobjectxyperm (LOCALID_RIVAL2, 3, 32)
	setobjectmovementtype (LOCALID_RIVAL2, MOVEMENT_TYPE_LOOK_AROUND)
}

script Route110_EventScript_BeginCylcingRoadChallenge {
	special (Special_BeginCyclingRoadChallenge)
	setvar (VAR_CYCLING_CHALLENGE_STATE, 2)
	return
}

raw `
