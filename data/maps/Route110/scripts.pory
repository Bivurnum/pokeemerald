Route110_EventScript_CyclingChallengeEnd::
	lockall
	applymovement LOCALID_CHALLENGE_BIKER, Common_Movement_WalkInPlaceFasterRight
	waitmovement 0
	call Route110_EventScript_CyclingChallengeResults
	releaseall
	end

Route110_EventScript_CyclingChallengeResults::
	special FinishCyclingRoadChallenge
	msgbox Route110_Text_CyclingChallengeResultSummary, MSGBOX_DEFAULT
	switch VAR_RESULT
	case 10, Route110_EventScript_ChallengeReactionBest
	case 9, Route110_EventScript_ChallengeReactionGood
	case 8, Route110_EventScript_ChallengeReactionGood
	case 7, Route110_EventScript_ChallengeReactionGood
	case 6, Route110_EventScript_ChallengeReactionOk
	case 5, Route110_EventScript_ChallengeReactionOk
	case 4, Route110_EventScript_ChallengeReactionOk
	case 3, Route110_EventScript_ChallengeReactionBad
	case 2, Route110_EventScript_ChallengeReactionBad
	case 1, Route110_EventScript_ChallengeReactionBad
	case 0, Route110_EventScript_ChallengeReactionWorst
	end

Route110_EventScript_ChallengeReactionBest::
	msgbox Route110_Text_ChallengeReactionBest, MSGBOX_DEFAULT
	goto Route110_EventScript_EndChallenge
	end

Route110_EventScript_ChallengeReactionGood::
	msgbox Route110_Text_ChallengeReactionGood, MSGBOX_DEFAULT
	goto Route110_EventScript_EndChallenge
	end

Route110_EventScript_ChallengeReactionOk::
	msgbox Route110_Text_ChallengeReactionOk, MSGBOX_DEFAULT
	goto Route110_EventScript_EndChallenge
	end

Route110_EventScript_ChallengeReactionBad::
	msgbox Route110_Text_ChallengeReactionBad, MSGBOX_DEFAULT
	goto Route110_EventScript_EndChallenge
	end

Route110_EventScript_ChallengeReactionWorst::
	msgbox Route110_Text_ChallengeReactionWorst, MSGBOX_DEFAULT
	goto Route110_EventScript_EndChallenge
	end

Route110_EventScript_EndChallenge::
	setvar VAR_CYCLING_CHALLENGE_STATE, 3
	savebgm MUS_DUMMY
	fadedefaultbgm
	return
`

script Route110_EventScript_RivalTrigger1 {
	setvar (VAR_0x8008, 1)
	goto (Route110_EventScript_RivalScene)
	end
}

script Route110_EventScript_RivalTrigger2 {
	setvar (VAR_0x8008, 2)
	goto (Route110_EventScript_RivalScene)
	end
}

script Route110_EventScript_RivalTrigger3 {
	setvar (VAR_0x8008, 3)
	goto (Route110_EventScript_RivalScene)
	end
}

script Route110_EventScript_RivalScene {
	lockall
	checkplayergender
	playbgm (MUS_ENCOUNTER_BRENDAN, FALSE)
	applymovement (LOCALID_RIVAL2, Common_Movement_WalkInPlaceFasterDown)
	waitmovement (0)
	applymovement (LOCALID_RIVAL2, Common_Movement_ExclamationMark)
	waitmovement (0)
	applymovement (LOCALID_RIVAL2, Common_Movement_Delay48)
	waitmovement (0)
	delay (30)
	switch (var(VAR_0x8008)) {
		case 1:
			applymovement (LOCALID_RIVAL2, Route110_Movement_RivalApproachPlayer1)
		case 2:
			applymovement (LOCALID_RIVAL2, Route110_Movement_RivalApproachPlayer2)
		case 3:
			applymovement (LOCALID_RIVAL2, Route110_Movement_RivalApproachPlayer3)
	}
	waitmovement (0)
	rival2talk (Route110_Text_SpencerEvolved,
				Route110_Text_BrenEvolved,
				Route110_Text_KyleEvolved)
	if (var(VAR_0x8008) == 1) {
		setobjectxyperm (LOCALID_RIVAL1, 35, 62)
	}
	addobject (LOCALID_RIVAL1)
	playse (SE_PIN)
	switch (var(VAR_0x8008)) {
		case 1:
			applymovement (OBJ_EVENT_ID_PLAYER, Route110_Movement_PlayerWatchRival1RunIn1)
			applymovement (LOCALID_RIVAL2, Route110_Movement_Rival2WatchRival1RunIn1)
			applymovement (LOCALID_RIVAL1, Route110_Movement_Rival1RunsIn1)
		default:
			applymovement (OBJ_EVENT_ID_PLAYER, Route110_Movement_PlayerWatchRival1RunIn2and3)
			applymovement (LOCALID_RIVAL2, Route110_Movement_Rival2WatchRival1RunIn2and3)
			applymovement (LOCALID_RIVAL1, Route110_Movement_Rival1RunsIn2and3)
	}
	waitmovement (0)
	if (var(VAR_0x8008) == 3) {
		applymovement (LOCALID_RIVAL1, Rival1ExtraStep)
		waitmovement (0)
	}
	rival1talk (Route110_Text_SpencerAlmostMissedYou,
				Route110_Text_BrenAlmostMissedYou,
				Route110_Text_KyleAlmostMissedYou)
	if (var(VAR_0x8008) == 1) {
		applymovement (LOCALID_RIVAL2, Common_Movement_BeginTalkRight)
	}
	else {
		applymovement (LOCALID_RIVAL2, Common_Movement_BeginTalkLeft)
	}
	waitmovement (0)
	rival2talk (Route110_Text_SpencerBoughtItemfinders,
				Route110_Text_BrenBoughtItemfinders,
				Route110_Text_KyleBoughtItemfinders)
	delay (16)
	if (var(VAR_0x8008) == 1) {
		applymovement (LOCALID_RIVAL2, Common_Movement_BeginTalkRight)
	}
	else {
		applymovement (LOCALID_RIVAL2, Common_Movement_BeginTalkLeft)
	}
	waitmovement (0)
	delay (30)
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterUp)
	applymovement (LOCALID_RIVAL2, Common_Movement_BeginTalkDown)
	waitmovement (0)
	msgbox (Route110_Text_AndOneForYou, MSGBOX_DEFAULT)
	closemessage
	delay (30)
	giveitem (ITEM_DOWSING_MACHINE)
	rival2talk (Route110_Text_SpencerLetsLookAround,
				Route110_Text_BrenLetsLookAround,
				Route110_Text_KyleLetsLookAround)
	if (var(VAR_0x8008) == 1) {
		applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterRight)
		applymovement (LOCALID_RIVAL2, Common_Movement_WalkInPlaceFasterRight)
		applymovement (LOCALID_RIVAL1, Common_Movement_BeginTalkLeft)
	}
	else {
		applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterLeft)
		applymovement (LOCALID_RIVAL2, Common_Movement_WalkInPlaceFasterLeft)
		applymovement (LOCALID_RIVAL1, Common_Movement_BeginTalkRight)
	}
	waitmovement (0)
	rival1talk (Route110_Text_SpencerLetsGo,
				Route110_Text_BrenLetsGo,
				Route110_Text_KyleLetsGo)
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterUp)
	applymovement (LOCALID_RIVAL1, Route110_Movement_Rival1Exit)
	applymovement (LOCALID_RIVAL2, Route110_Movement_Rival2Exit)
	waitmovement (0)
	removeobject (LOCALID_RIVAL1)
	setobjectxy (LOCALID_RIVAL2, 3, 30)
	setobjectxyperm (LOCALID_RIVAL2, 3, 30)
	setobjectmovementtype (LOCALID_RIVAL2, MOVEMENT_TYPE_LOOK_AROUND)
	setvar (VAR_ROUTE110_STATE, 1)
	setflag (FLAG_HIDE_ROUTE_103_RIVAL1_LATER)
	fadedefaultbgm
	releaseall
	end
}

script Route110_EventScript_Rival1 {
	lock
	checkflag (FLAG_HIDDEN_ITEM_ROUTE_110_REVIVE)
	if (var(VAR_RESULT) == FALSE) {
		playse (SE_ITEMFINDER)
		waitse
		playse (SE_ITEMFINDER)
		waitse
		playse (SE_ITEMFINDER)
		waitse
		applymovement (LOCALID_RIVAL1FINDER, Route110_Movement_Rival1Itemfinder)
		waitmovement (0)
		applymovement (LOCALID_RIVAL1FINDER, Common_Movement_FacePlayer)
		waitmovement (0)
		rival1talk (Route110_Text_SpencerCantFindItem,
					Route110_Text_BrenCantFindItem,
					Route110_Text_KyleCantFindItem)
		applymovement (LOCALID_RIVAL1FINDER, Common_Movement_WalkInPlaceFasterRight)
		waitmovement (0)
	}
	else {
		applymovement (LOCALID_RIVAL1FINDER, Common_Movement_FacePlayer)
		waitmovement (0)
		rival1talk (Route110_Text_SpencerStupidMachine,
					Route110_Text_BrenStupidMachine,
					Route110_Text_KyleStupidMachine)
	}
	release
	end
}

movement Route110_Movement_RivalApproachPlayer1 {
	walk_down
	walk_left
	walk_in_place_faster_down
}

movement Route110_Movement_RivalApproachPlayer2 {
	walk_down
}

movement Route110_Movement_RivalApproachPlayer3 {
	walk_down
	walk_right
	walk_in_place_faster_down
}

movement Route110_Movement_PlayerWatchRival1RunIn1 {
	face_down
	delay_4 * 5
	walk_in_place_right
	delay_8
	walk_in_place_up
	delay_4 * 3
	delay_16 * 4
	walk_in_place_faster_right
}

movement Route110_Movement_Rival2WatchRival1RunIn1 {
	emote_exclamation_mark
	face_down
	delay_4 * 6
	walk_in_place_right
	delay_8
	walk_in_place_up
	delay_4 * 2
	delay_16 * 4
	walk_in_place_faster_right
}

movement Route110_Movement_Rival1RunsIn1 {
	walk_fast_up * 10
	walk_in_place_fast_up * 6
	walk_fast_down * 3
	walk_fast_left
}

movement Route110_Movement_PlayerWatchRival1RunIn2and3 {
	face_down
	delay_4 * 5
	walk_in_place_left
	delay_8
	walk_in_place_up
	delay_4 * 3
	delay_16 * 4
	walk_in_place_faster_left
}

movement Route110_Movement_Rival2WatchRival1RunIn2and3 {
	emote_exclamation_mark
	face_down
	delay_4 * 6
	walk_in_place_left
	delay_8
	walk_in_place_up
	delay_4 * 2
	delay_16 * 4
	walk_in_place_faster_left
}

movement Route110_Movement_Rival1RunsIn2and3 {
	walk_fast_up * 10
	walk_in_place_fast_up * 6
	walk_fast_down * 3
	walk_in_place_faster_right
}

movement Rival1ExtraStep {
	walk_fast_right
}

movement Route110_Movement_Rival1Exit {
	walk_fast_up
	walk_fast_up
	walk_fast_up
	walk_fast_up
	walk_fast_up
	walk_fast_up
	walk_fast_up
}

movement Route110_Movement_Rival2Exit {
	walk_in_place_faster_up
	delay_8 * 3
	walk_fast_up
	walk_fast_up
	walk_fast_up
	walk_fast_up
	walk_fast_up
	walk_fast_up
	walk_fast_up
}

movement Route110_Movement_Rival1Itemfinder {
	walk_in_place_right
	delay_16 * 2
}

