text Route110_Text_SpencerBoughtItemfinders {
	format ("SPENCER: Yo, {RIVAL}!\N"
		"I was just telling {PLAYER} here that\N"
		"I spent my battle earnings on some\N"
		"Dowsing Machines for the three of us.\N"
		"Here. Take one!")
}

text Route110_Text_BrenBoughtItemfinders {
