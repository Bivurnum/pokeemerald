text MauvilleCity_BikeShop_Text_RydellFilthyShoes {
	format ("Did you boys say you're on a long journey?\p"
		"Where are my manners?\N"
		"My name is RYDELL.\N"
		"I'm the owner of this shop.\p"
		"Your RUNNING SHOES…\N"
		"They're awfully filthy.\N"
		"Did you come from far away?")
}

text MauvilleCity_BikeShop_Text_RydellDontBeModest {
	format ("RYDELL: Now, now…\N"
		"Don't be modest.\p"
		"I overheard you talking before.\N"
		"You must've come a long way!")
}

text MauvilleCity_BikeShop_Text_RydellCameAllThisWay {
	format ("RYDEL: Hm, hm… … … … …\p"
		"You're saying that you came all this\n"
		"way from LITTLEROOT?\p"
		"My goodness!\n"
		"That's ridiculously far!\p"
		"And you say you have even further\N"
		"to go still?")
}

text MauvilleCity_BikeShop_Text_SpencerTakingGymChallenge {
	format ("SPENCER: Yeah.\N"
		"We're taking the GYM challenge, so we'll be travelling to all the GYMS around the region!")
}

text MauvilleCity_BikeShop_Text_BrenTakingGymChallenge {
	format ("BREN: Yeah.\N"
