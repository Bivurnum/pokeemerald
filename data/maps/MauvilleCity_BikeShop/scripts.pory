const LOCALID_RYDEL = 1
const LOCALID_RIVAL1 = 2
const LOCALID_RIVAL2 = 3

mapscripts MauvilleCity_BikeShop_MapScripts {
	MAP_SCRIPT_ON_TRANSITION {
		call (Common_EventScript_SetupRivalGfxId)
		call_if_eq (VAR_MAUVILLE_BIKE_SHOP_STATE, 0, MauvilleCity_BikeShop_EventScript_SetUpBikeIntro)
	}
}

script MauvilleCity_BikeShop_EventScript_SetUpBikeIntro {
	setobjectxyperm (LOCALID_RYDEL, 9, 7)
	setobjectmovementtype (LOCALID_RYDEL, MOVEMENT_TYPE_FACE_RIGHT)
	setobjectxyperm (LOCALID_RIVAL1, 2, 5)
	setobjectmovementtype (LOCALID_RIVAL1, MOVEMENT_TYPE_FACE_LEFT)
}

script MauvilleCity_BikeShop_EventScript_Rival1 {
	lockall
	applymovement (LOCALID_RIVAL1, Common_Movement_FacePlayer)
	waitmovement (0)
	goto_if_eq (VAR_MAUVILLE_BIKE_SHOP_STATE, 0, MauvilleCity_BikeShop_EventScript_BikeIntro)
	if (var(VAR_TEMP_3) != 5) {
		msgbox (MauvilleCity_BikeShop_Text_YouWantToRead, MSGBOX_YESNO)
		switch (var(VAR_RESULT)) {
			case NO:
				msgbox ("Suit yourself.")
				closemessage
				applymovement (LOCALID_RIVAL1, Common_Movement_FaceUp)
				waitmovement (0)
			case YES:
				msgbox ("Go right ahead.")
				closemessage
				getplayerxy (VAR_0x8001, VAR_0x8002)
				if (var(VAR_0x8001) == 7) {
					applymovement (LOCALID_RIVAL1, MauvilleCity_BikeShop_Movement_LetPlayerReadRight)
				}
				else {
					applymovement (LOCALID_RIVAL1, MauvilleCity_BikeShop_Movement_LetPlayerReadLeft)
				}
				waitmovement (0)
				setvar (VAR_TEMP_3, 5)
		}
	}
	else {
		rival1talk (MauvilleCity_BikeShop_Text_SpencerUsefulInfo,
					MauvilleCity_BikeShop_Text_BrenUsefulInfo,
					MauvilleCity_BikeShop_Text_KyleUsefulInfo)
	}
	releaseall
	end
}

movement MauvilleCity_BikeShop_Movement_LetPlayerReadLeft {
	walk_left
	walk_in_place_fast_right
}

movement MauvilleCity_BikeShop_Movement_LetPlayerReadRight {
	walk_right
	walk_in_place_fast_left
}

text MauvilleCity_BikeShop_Text_YouWantToRead {
	format ("Oh! Did you want to read\N"
		"this manual?")
}

text MauvilleCity_BikeShop_Text_SpencerUsefulInfo {
	format ("It's useful information, right?")
}

text MauvilleCity_BikeShop_Text_BrenUsefulInfo {
	format ("It's useful information, right?")
}

text MauvilleCity_BikeShop_Text_KyleUsefulInfo {
	format ("It's useful information, right?")
}

script MauvilleCity_BikeShop_EventScript_BikeIntro {
	rival1talk (MauvilleCity_BikeShop_Text_SpencerBikesLookCool,
				MauvilleCity_BikeShop_Text_BrenBikesLookCool,
				MauvilleCity_BikeShop_Text_KyleBikesLookCool)
	delay (30)
	playse (SE_EXIT)
	addobject (LOCALID_RIVAL2)
	waitse
	playse (SE_PIN)
	applymovement (OBJ_EVENT_ID_PLAYER, MauvilleCity_BikeShop_Movement_Surprise)
	applymovement (LOCALID_RIVAL1, MauvilleCity_BikeShop_Movement_Surprise)
	waitmovement (0)
	delay (40)
	waitse
	getplayerxy (VAR_0x8001, VAR_0x8002)
	switch (var(VAR_0x8002)) {
		case 4:
			applymovement (OBJ_EVENT_ID_PLAYER, MauvilleCity_BikeShop_Movement_PlayerMoveIntoPlaceTop)
		case 6:
			applymovement (OBJ_EVENT_ID_PLAYER, MauvilleCity_BikeShop_Movement_PlayerMoveIntoPlaceBottom)
	}
	waitmovement (0)
	applymovement (OBJ_EVENT_ID_PLAYER, MauvilleCity_BikeShop_Movement_GreetRival2)
	applymovement (LOCALID_RIVAL1, MauvilleCity_BikeShop_Movement_GreetRival2)
	applymovement (LOCALID_RIVAL2, MauvilleCity_BikeShop_Movement_Rival2Enter)
	waitmovement (0)
	applymovement (LOCALID_RIVAL2, Common_Movement_BeginTalkUp)
	waitmovement (0)
	rival2talk (MauvilleCity_BikeShop_Text_SpencerWhyDidntYouTellMe,
				MauvilleCity_BikeShop_Text_BrenWhyDidntYouTellMe,
				MauvilleCity_BikeShop_Text_KyleWhyDidntYouTellMe)
	applymovement (LOCALID_RIVAL1, Common_Movement_BeginTalkDown)
	waitmovement (0)
	rival1talk (MauvilleCity_BikeShop_Text_SpencerTriedTo,
				MauvilleCity_BikeShop_Text_BrenTriedTo,
				MauvilleCity_BikeShop_Text_KyleTriedTo)
	applymovement (LOCALID_RIVAL2, Common_Movement_BeginTalkUp)
	waitmovement (0)
	rival2talk (MauvilleCity_BikeShop_Text_SpencerMyBad,
				MauvilleCity_BikeShop_Text_BrenMyBad,
				MauvilleCity_BikeShop_Text_KyleMyBad)
	applymovement (LOCALID_RIVAL1, Common_Movement_BeginTalkDown)
	waitmovement (0)
	rival1talk (MauvilleCity_BikeShop_Text_SpencerWouldBeNiceToHaveBikes,
				MauvilleCity_BikeShop_Text_BrenWouldBeNiceToHaveBikes,
				MauvilleCity_BikeShop_Text_KyleWouldBeNiceToHaveBikes)
	playse (SE_PIN)
	applymovement (LOCALID_RYDEL, Common_Movement_ExclamationMark)
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_FaceRight)
	applymovement (LOCALID_RIVAL1, Common_Movement_FaceRight)
	applymovement (LOCALID_RIVAL2, Common_Movement_FaceRight)
	waitmovement (0)
	delay (60)
	waitse
	applymovement (LOCALID_RIVAL1, MauvilleCity_BikeShop_Movement_Rival1GetInPlace)
	applymovement (LOCALID_RYDEL, MauvilleCity_BikeShop_Movement_RydellApproaches)
	waitmovement (0)
	applymovement (LOCALID_RYDEL, Common_Movement_BeginTalkLeft)
	waitmovement (0)
	msgbox (MauvilleCity_BikeShop_Text_RydellFilthyShoes, MSGBOX_YESNO)
	call_if_eq (VAR_RESULT, NO, MauvilleCity_BikeShop_EventScript_ChoseNo)
	closemessage
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_BeginTalkRight)
	waitmovement (0)
	delay (20)
	applymovement (LOCALID_RYDEL, Common_Movement_BeginTalkLeft)
	waitmovement (0)
	msgbox (MauvilleCity_BikeShop_Text_RydellCameAllThisWay)
	closemessage
	applymovement (LOCALID_RIVAL2, Common_Movement_BeginTalkRight)
	waitmovement (0)
	rival2talk (MauvilleCity_BikeShop_Text_SpencerTakingGymChallenge,
				MauvilleCity_BikeShop_Text_BrenTakingGymChallenge,
				MauvilleCity_BikeShop_Text_KyleTakingGymChallenge)
	delay (10)
	applymovement (LOCALID_RIVAL1, Common_Movement_BeginTalkRight)
	waitmovement (0)
	rival1talk (MauvilleCity_BikeShop_Text_SpencerPokedexJourney,
				MauvilleCity_BikeShop_Text_BrenPokedexJourney,
				MauvilleCity_BikeShop_Text_KylePokedexJourney)
	applymovement (LOCALID_RYDEL, Common_Movement_BeginTalkLeft)
	waitmovement (0)
	msgbox (MauvilleCity_BikeShop_Text_ThatSettlesIt)
	waitmessage
	multichoice (21, 8, MULTI_BIKE, TRUE)
	switch (var(VAR_RESULT)) {
		case 0:
			goto (MauvilleCity_BikeShop_EventScript_GetMachBike)
		case 1:
			goto (MauvilleCity_BikeShop_EventScript_GetAcroBike)
	}
	end
}

script MauvilleCity_BikeShop_EventScript_ChoseNo {
	msgbox (MauvilleCity_BikeShop_Text_RydellDontBeModest)
	return
}

script MauvilleCity_BikeShop_EventScript_IntroPostBikeChoice {
	msgbox (MauvilleCity_BikeShop_Text_ExcellentChoice)
	closemessage
	applymovement (LOCALID_RYDEL, MauvilleCity_BikeShop_Movement_RydellToRival2)
	waitmovement (0)
	delay (20)
	applymovement (LOCALID_RIVAL2, Common_Movement_BeginTalkRight)
	waitmovement (0)
	rival2talk (MauvilleCity_BikeShop_Text_SpencerChooseAcro,
				MauvilleCity_BikeShop_Text_BrenChooseAcro,
				MauvilleCity_BikeShop_Text_KyleChooseAcro)
	delay (60)
	applymovement (LOCALID_RYDEL, MauvilleCity_BikeShop_Movement_RydellToRival1)
	waitmovement (0)
	applymovement (LOCALID_RIVAL1, Common_Movement_BeginTalkRight)
	waitmovement (0)
	rival1talk (MauvilleCity_BikeShop_Text_SpencerChooseMach,
				MauvilleCity_BikeShop_Text_BrenChooseMach,
				MauvilleCity_BikeShop_Text_KyleChooseMach)
	delay (60)
	applymovement (LOCALID_RYDEL, Common_Movement_Walk_Down)
	waitmovement (0)
	applymovement (LOCALID_RYDEL, Common_Movement_BeginTalkLeft)
	waitmovement (0)
	msgbox (MauvilleCity_BikeShop_Text_ComeBackToSwitchBikes)
	closemessage
	applymovement (LOCALID_RYDEL, MauvilleCity_BikeShop_Movement_RydellReturnToWork)
	waitmovement (0)
	applymovement (LOCALID_RIVAL2, Common_Movement_FaceUp)
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterDown)
	applymovement (LOCALID_RIVAL1, MauvilleCity_BikeShop_Movement_Rival1AfterRydell)
	waitmovement (0)
	applymovement (LOCALID_RIVAL2, Common_Movement_BeginTalkUp)
	waitmovement (0)
	rival2talk (MauvilleCity_BikeShop_Text_SpencerGoTryBike,
				MauvilleCity_BikeShop_Text_BrenGoTryBike,
				MauvilleCity_BikeShop_Text_KyleGoTryBike)
	applymovement (LOCALID_RIVAL2, MauvilleCity_BikeShop_Movement_Rival2Leaves)
	waitmovement (0)
	delay (20)
	playse (SE_EXIT)
	removeobject (LOCALID_RIVAL2)
	waitse
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_FaceRight)
	applymovement (LOCALID_RIVAL1, Common_Movement_BeginTalkLeft)
	waitmovement (0)
	rival1talk (MauvilleCity_BikeShop_Text_SpencerLookUpManual,
				MauvilleCity_BikeShop_Text_BrenLookUpManual,
				MauvilleCity_BikeShop_Text_KyleLookUpManual)
	applymovement (LOCALID_RIVAL1, MauvilleCity_BikeShop_Movement_Rival1GoToManual)
	waitmovement (0)
	setobjectxyperm (LOCALID_RIVAL1, 8, 2)
	setvar (VAR_MAUVILLE_BIKE_SHOP_STATE, 1)
	clearflag (FLAG_HIDE_ROUTE_110_RIVAL)
	setflag (FLAG_RECEIVED_BIKE)
	setflag (FLAG_HIDE_MAP_NAME_POPUP)
	releaseall
	end
}

movement MauvilleCity_BikeShop_Movement_Surprise {
	emote_exclamation_mark
	walk_in_place_faster_down
}

movement MauvilleCity_BikeShop_Movement_PlayerMoveIntoPlaceTop {
	walk_right
	walk_down
}

movement MauvilleCity_BikeShop_Movement_PlayerMoveIntoPlaceBottom {
	walk_right
	walk_up
}

movement MauvilleCity_BikeShop_Movement_GreetRival2 {
	walk_right
	walk_in_place_faster_down
}

movement MauvilleCity_BikeShop_Movement_Rival2Enter {
	walk_up * 2
}

movement MauvilleCity_BikeShop_Movement_RydellApproaches {
	walk_left * 2
	walk_up * 2
	walk_left * 2
}

movement MauvilleCity_BikeShop_Movement_Rival1GetInPlace {
	walk_up
	walk_right
}

movement MauvilleCity_BikeShop_Movement_RydellToRival2 {
	walk_down
	walk_in_place_faster_left
}

movement MauvilleCity_BikeShop_Movement_RydellToRival1 {
	walk_up * 2
	walk_in_place_faster_left
}

movement MauvilleCity_BikeShop_Movement_RydellReturnToWork {
	walk_right * 2
	walk_down * 2
	walk_right * 2
}

movement MauvilleCity_BikeShop_Movement_Rival1AfterRydell {
	walk_right
	walk_down
}

movement MauvilleCity_BikeShop_Movement_Rival2Leaves {
	walk_down * 2
}

movement MauvilleCity_BikeShop_Movement_Rival1GoToManual {
	walk_right * 3
	walk_up * 3
}

