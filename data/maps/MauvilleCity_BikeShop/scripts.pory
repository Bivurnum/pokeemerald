text MauvilleCity_BikeShop_Text_SpencerPokedexJourney {
	format ("SPENCER: Not to mention that the PROF. tasked us with filling out the POKéDEX.\N"
		"We will be searching far and wide to find as many species of POKéMON as we can!")
}

text MauvilleCity_BikeShop_Text_BrenPokedexJourney {
	format ("BREN: Not to mention that the PROF. tasked us with filling out the POKéDEX.\N"
		"We will be searching far and wide to find as many species of POKéMON as we can!")
}

text MauvilleCity_BikeShop_Text_KylePokedexJourney {
