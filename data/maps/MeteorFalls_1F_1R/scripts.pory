const LOCALID_MAGMA_GRUNT_1 = 5
const LOCALID_MAGMA_GRUNT_2 = 6
const LOCALID_ARCHIE = 7
const LOCALID_AQUA_GRUNT_1 = 8
const LOCALID_AQUA_GRUNT_2 = 9
const LOCALID_COSMO = 10
const LOCALID_RIVAL1 = 11

const RIGHT = 1
const UP = 2
const LEFT = 3

raw `
.set LOCALID_MAGMA_GRUNT_1, 5
.set LOCALID_MAGMA_GRUNT_2, 6
.set LOCALID_ARCHIE, 7
.set LOCALID_AQUA_GRUNT_1, 8
.set LOCALID_AQUA_GRUNT_2, 9
.set LOCALID_COSMO, 10
.set LOCALID_RIVAL1, 11

.set RIGHT, 1
.set UP, 2
.set LEFT, 3
`

mapscripts MeteorFalls_1F_1R_MapScripts {
	MAP_SCRIPT_ON_TRANSITION {
		call (Common_EventScript_SetupRivalGfxId)
	}
	MAP_SCRIPT_ON_LOAD {
		call_if_set (FLAG_SYS_GAME_CLEAR, MeteorFalls_1F_1R_EventScript_OpenStevensCave)
	}
	MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_METEOR_FALLS_STATE, 1: MeteorFalls_1F_1R_EventScript_InitRival1
	]
}

script MeteorFalls_1F_1R_EventScript_OpenStevensCave {
	setmetatile (4, 1, METATILE_MeteorFalls_CaveEntrance_Top, TRUE)
	setmetatile (3, 2, METATILE_MeteorFalls_CaveEntrance_Left, TRUE)
	setmetatile (4, 2, METATILE_MeteorFalls_CaveEntrance_Bottom, FALSE)
	setmetatile (5, 2, METATILE_MeteorFalls_CaveEntrance_Right, TRUE)
	return
}

script MeteorFalls_1F_1R_EventScript_InitRival1 {
	lock
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterLeft)
	applymovement (LOCALID_RIVAL1, Common_Movement_BeginTalkRight)
	waitmovement (0)
	rival1talk (MeteorFalls_1F_1R_Text_SpencerOverHere,
				MeteorFalls_1F_1R_Text_BrenOverHere,
				MeteorFalls_1F_1R_Text_KyleOverHere)
	closemessage
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_Walk_Left)
	waitmovement (0)
	rival1talk (MeteorFalls_1F_1R_Text_SpencerStrangeVoices,
				MeteorFalls_1F_1R_Text_BrenStrangeVoices,
				MeteorFalls_1F_1R_Text_KyleStrangeVoices)
	closemessage
	setvar (VAR_METEOR_FALLS_STATE, 3)
	release
	end
}

text MeteorFalls_1F_1R_Text_SpencerOverHere {
	format ("Psssst…\n"
		"Over here…")
}

text MeteorFalls_1F_1R_Text_BrenOverHere {
	format ("Psssst…\n"
		"Over here…")
}

text MeteorFalls_1F_1R_Text_KyleOverHere {
	format ("Psssst…\n"
		"Over here…")
}

text MeteorFalls_1F_1R_Text_SpencerStrangeVoices {
	format ("I keep hearing strange echoes in here.\N"
		"Almost like the walls are whispering.\N"
		"Do you think there are ghosts in here?\p"
		"Hey! You're super strong.\N"
		"Will you go check it out, just in case?")
}

text MeteorFalls_1F_1R_Text_BrenStrangeVoices {
	format ("I keep hearing strange echoes in here.\N"
		"Almost like the walls are whispering.\N"
		"Do you think there are ghosts in here?\p"
		"Hey! You're super strong.\N"
		"Will you go check it out, just in case?")
}

text MeteorFalls_1F_1R_Text_KyleStrangeVoices {
	format ("I keep hearing strange echoes in here.\N"
		"Almost like the walls are whispering.\N"
		"Do you think there are ghosts in here?\p"
		"Hey! You're super strong.\N"
		"Will you go check it out, just in case?")
}

script MeteorFalls_1F_1R_EventScript_Rival1 {
	lock
	applymovement (LOCALID_RIVAL1, Common_Movement_FacePlayer)
	waitmovement (0)
	rival1talk (MeteorFalls_1F_1R_Text_SpencerYouCanClearGhosts,
				MeteorFalls_1F_1R_Text_BrenYouCanClearGhosts,
				MeteorFalls_1F_1R_Text_KyleYouCanClearGhosts)
	closemessage
	release
	end
}

text MeteorFalls_1F_1R_Text_SpencerYouCanClearGhosts {
	format ("I'm sure you're strong enough to clear the area of ghosts, right?")
}

text MeteorFalls_1F_1R_Text_BrenYouCanClearGhosts {
	format ("I'm sure you're strong enough to clear the area of ghosts, right?")
}

text MeteorFalls_1F_1R_Text_KyleYouCanClearGhosts {
	format ("I'm sure you're strong enough to clear the area of ghosts, right?")
}

script MeteorFalls_1F_1R_EventScript_MagmaStealsMeteoriteScene {
	lockall
	removeobject (LOCALID_RIVAL1)
	setobjectxyperm (LOCALID_RIVAL1, 22, 18)
	addobject (LOCALID_RIVAL1)
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceDown)
	applymovement (LOCALID_RIVAL1, MeteorFalls_1F_1R_Movement_Rival1WalkIn)
	waitmovement (0)
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_FaceRight)
	waitmovement (0)
	rival1talk (MeteorFalls_1F_1R_Text_SpencerWhatsGoingOn,
				MeteorFalls_1F_1R_Text_BrenWhatsGoingOn,
				MeteorFalls_1F_1R_Text_KyleWhatsGoingOn)
	closemessage
	playbgm (MUS_ENCOUNTER_MAGMA, FALSE)
	special (SpawnCameraObject)
	playse (SE_PIN)
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_FaceDown)
	applymovement (LOCALID_RIVAL1, MeteorFalls_1F_1R_Movement_NoticeMagma)
	applymovement (OBJ_EVENT_ID_CAMERA, MeteorFalls_1F_1R_Movement_CameraPanToMagma)
	waitmovement (0)
	applymovement (LOCALID_MAGMA_GRUNT_1, Common_Movement_WalkInPlaceDown)
	waitmovement (0)
	msgbox (MeteorFalls_1F_1R_Text_WithThisMeteorite, MSGBOX_DEFAULT)
	closemessage
	applymovement (LOCALID_MAGMA_GRUNT_1, Common_Movement_WalkInPlaceFasterUp)
	applymovement (LOCALID_MAGMA_GRUNT_2, Common_Movement_WalkInPlaceFasterUp)
	waitmovement (0)
	playse (SE_PIN)
	applymovement (LOCALID_MAGMA_GRUNT_1, Common_Movement_ExclamationMark)
	waitmovement (0)
	applymovement (LOCALID_MAGMA_GRUNT_1, Common_Movement_Delay48)
	waitmovement (0)
	msgbox (MeteorFalls_1F_1R_Text_DontExpectMercyFromMagma, MSGBOX_DEFAULT)
	closemessage
	applymovement (LOCALID_MAGMA_GRUNT_1, MeteorFalls_1F_1R_Movement_MagmaGruntApproachPlayer)
	waitmovement (0)
	msgbox (MeteorFalls_1F_1R_Text_HoldItRightThereMagma, MSGBOX_DEFAULT)
	closemessage
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterLeft)
	applymovement (LOCALID_RIVAL1, Common_Movement_WalkInPlaceFasterLeft)
	applymovement (LOCALID_MAGMA_GRUNT_1, Common_Movement_WalkInPlaceFasterLeft)
	applymovement (LOCALID_MAGMA_GRUNT_2, Common_Movement_WalkInPlaceFasterLeft)
	waitmovement (0)
	addobject (LOCALID_ARCHIE)
	addobject (LOCALID_AQUA_GRUNT_1)
	addobject (LOCALID_AQUA_GRUNT_2)
	playbgm (MUS_ENCOUNTER_AQUA, FALSE)
	applymovement (LOCALID_ARCHIE, MeteorFalls_1F_1R_Movement_ArchieArrive)
	applymovement (LOCALID_AQUA_GRUNT_1, MeteorFalls_1F_1R_Movement_AquaGrunt1Arrive)
	applymovement (LOCALID_AQUA_GRUNT_2, MeteorFalls_1F_1R_Movement_AquaGrunt2Arrive)
	waitmovement (0)
	applymovement (LOCALID_MAGMA_GRUNT_1, Common_Movement_WalkInPlaceFasterLeft)
	applymovement (LOCALID_MAGMA_GRUNT_2, Common_Movement_WalkInPlaceFasterLeft)
	waitmovement (0)
	msgbox (MeteorFalls_1F_1R_Text_BeSeeingYouTeamAqua, MSGBOX_DEFAULT)
	closemessage
	applymovement (LOCALID_RIVAL1, MeteorFalls_1F_1R_Movement_PushRival1OutOfWayRight)
	applymovement (OBJ_EVENT_ID_PLAYER, MeteorFalls_1F_1R_Movement_PushPlayerOutOfWay)
	applymovement (LOCALID_MAGMA_GRUNT_1, MeteorFalls_1F_1R_Movement_MagmaGrunt1Exit)
	applymovement (LOCALID_MAGMA_GRUNT_2, MeteorFalls_1F_1R_Movement_MagmaGrunt2Exit)
	waitmovement (0)
	removeobject (LOCALID_MAGMA_GRUNT_1)
	removeobject (LOCALID_MAGMA_GRUNT_2)
	applymovement (LOCALID_RIVAL1, MeteorFalls_1F_1R_Movement_Rival1GetInPlaceForArchieRight)
	applymovement (OBJ_EVENT_ID_CAMERA, MeteorFalls_1F_1R_Movement_CameraPanBack)
	applymovement (LOCALID_ARCHIE, MeteorFalls_1F_1R_Movement_ArchieApproachPlayer)
	waitmovement (0)
	special (RemoveCameraObject)
	msgbox (MeteorFalls_1F_1R_Text_ArchieSeenYouBefore, MSGBOX_DEFAULT)
	closemessage
	applymovement (LOCALID_AQUA_GRUNT_1, MeteorFalls_1F_1R_Movement_AquaGrunt1ApproachArchie)
	applymovement (LOCALID_AQUA_GRUNT_2, MeteorFalls_1F_1R_Movement_AquaGrunt2ApproachArchie)
	waitmovement (0)
	msgbox (MeteorFalls_1F_1R_Text_BossWeShouldChaseMagma, MSGBOX_DEFAULT)
	applymovement (LOCALID_ARCHIE, Common_Movement_WalkInPlaceFasterDown)
	waitmovement (0)
	msgbox (MeteorFalls_1F_1R_Text_ArchieYesNoTellingWhatMagmaWillDo, MSGBOX_DEFAULT)
	applymovement (LOCALID_ARCHIE, Common_Movement_WalkInPlaceFasterLeft)
	waitmovement (0)
	msgbox (MeteorFalls_1F_1R_Text_ArchieFarewell, MSGBOX_DEFAULT)
	closemessage
	applymovement (LOCALID_RIVAL1, Common_Movement_FaceRight)
	applymovement (LOCALID_ARCHIE, MeteorFalls_1F_1R_Movement_ArchieExit)
	applymovement (LOCALID_AQUA_GRUNT_1, MeteorFalls_1F_1R_Movement_AquaGrunt1Exit)
	applymovement (LOCALID_AQUA_GRUNT_2, MeteorFalls_1F_1R_Movement_AquaGrunt2Exit)
	waitmovement (0)
	fadedefaultbgm
	removeobject (LOCALID_ARCHIE)
	removeobject (LOCALID_AQUA_GRUNT_1)
	removeobject (LOCALID_AQUA_GRUNT_2)
	call (MeteorFalls_1F_1R_EventScript_Rival1AfterGrunts)
	setflag (FLAG_HIDE_METEOR_FALLS_RIVAL1)
	setflag (FLAG_HIDE_ROUTE_112_TEAM_MAGMA)
	setflag (FLAG_MET_ARCHIE_METEOR_FALLS)
	setflag (FLAG_HIDE_DIG_HOUSE_RIVAL2)
	setflag (FLAG_HIDE_FALLARBOR_TOWN_BATTLE_TENT_SCOTT)
	setflag (FLAG_MET_PROF_COZMO)
	setvar (VAR_METEOR_FALLS_STATE, 4)
	call (EndOfDemo) //DEMO
	releaseall
	end
}

movement MeteorFalls_1F_1R_Movement_Rival1WalkIn {
	walk_left * 7
}

movement MeteorFalls_1F_1R_Movement_NoticeMagma {
	emote_exclamation_mark
	face_down
}

movement MeteorFalls_1F_1R_Movement_CameraPanToMagma {
	delay_16 * 2
	walk_slow_down * 2
}

movement MeteorFalls_1F_1R_Movement_CameraPanBack {
	walk_slow_up
	walk_slow_diag_northwest
}

text MeteorFalls_1F_1R_Text_SpencerWhatsGoingOn {
	format ("SPENCER: What's going on?\n"
		"Did you find the ghosts?")
}

text MeteorFalls_1F_1R_Text_BrenWhatsGoingOn {
	format ("BREN: What's going on?\n"
		"Did you find the ghosts?")
}

text MeteorFalls_1F_1R_Text_KyleWhatsGoingOn {
	format ("KYLE: What's going on?\n"
		"Did you find the ghosts?")
}

script EndOfDemo {
	msgbox (format("// END OF DEMO //\nYou may play past this point, but the game may not function correctly."), MSGBOX_SIGN)
	closemessage
	return
}

raw `
MeteorFalls_1F_1R_Movement_MagmaGruntApproachPlayer:
	walk_right
	walk_right
	walk_in_place_faster_up
	step_end

MeteorFalls_1F_1R_Movement_MagmaGrunt1Exit:
	walk_fast_up
	walk_fast_up
	walk_fast_right
	walk_fast_right
	walk_fast_right
	walk_fast_right
	walk_fast_right
	walk_fast_right
	walk_fast_right
	step_end

MeteorFalls_1F_1R_Movement_MagmaGrunt2Exit:
	walk_fast_up
	walk_fast_up
	walk_fast_up
	walk_fast_right
	walk_fast_right
	walk_fast_right
	walk_fast_right
	walk_fast_right
	walk_fast_right
	walk_fast_right
	step_end

MeteorFalls_1F_1R_Movement_ArchieArrive:
	walk_right
	walk_right
	walk_right
	walk_right
	walk_right
	walk_right
	step_end

MeteorFalls_1F_1R_Movement_AquaGrunt1Arrive:
	delay_16
	delay_16
	walk_right
	walk_right
	walk_right
	walk_right
	walk_right
	step_end

MeteorFalls_1F_1R_Movement_AquaGrunt2Arrive:
	delay_16
	delay_16
	walk_right
	walk_right
	walk_right
	walk_right
	walk_right
	step_end

MeteorFalls_1F_1R_Movement_ArchieExit:
	walk_right
	walk_right
	walk_right
	walk_right
	walk_right
	walk_right
	walk_right
	step_end

MeteorFalls_1F_1R_Movement_ArchieApproachPlayer:
	walk_right
	walk_right
	walk_up
	walk_up
	walk_in_place_faster_left
	step_end

MeteorFalls_1F_1R_Movement_AquaGrunt1Exit:
	walk_up
	walk_up
	walk_right
	walk_right
	walk_right
	walk_right
	walk_right
	walk_right
	walk_right
	step_end

MeteorFalls_1F_1R_Movement_AquaGrunt1ApproachArchie:
	walk_right
	walk_right
	walk_right
	walk_in_place_faster_up
	step_end

MeteorFalls_1F_1R_Movement_AquaGrunt2Exit:
	walk_up
	walk_up
	walk_up
	walk_right
	walk_right
	walk_right
	walk_right
	walk_right
	walk_right
	walk_right
	step_end

MeteorFalls_1F_1R_Movement_AquaGrunt2ApproachArchie:
	walk_right
	walk_right
	walk_right
	walk_in_place_faster_up
	step_end

MeteorFalls_1F_1R_Movement_PushPlayerOutOfWay:
	walk_in_place_faster_down
	delay_4
	walk_in_place_faster_right
	lock_facing_direction
	walk_left
	unlock_facing_direction
	face_right
	step_end
`

movement MeteorFalls_1F_1R_Movement_Rival1MoveFromUp {
	walk_left
	walk_down
}

movement MeteorFalls_1F_1R_Movement_PushRival1OutOfWayRight {
	walk_in_place_faster_down
	delay_8 * 2
	lock_facing_direction
	walk_up
	unlock_facing_direction
	face_right
}

movement MeteorFalls_1F_1R_Movement_Rival1GetInPlaceForArchieLeft {
	walk_up
	walk_right * 2
	walk_in_place_faster_down
}

movement MeteorFalls_1F_1R_Movement_Rival1GetInPlaceForArchieRight {
	delay_16
	walk_left
	walk_in_place_faster_down
}

script MeteorFalls_1F_1R_EventScript_Rival1AfterGrunts {
	delay (20)
	applymovement (LOCALID_RIVAL1, MeteorFalls_1F_1R_Movement_Rival1ApproachPlayer)
	waitmovement (0)
	rival1talk (MeteorFalls_1F_1R_Text_SpencerShouldCheckOnCosmo,
				MeteorFalls_1F_1R_Text_BrenShouldCheckOnCosmo,
				MeteorFalls_1F_1R_Text_KyleShouldCheckOnCosmo)
	closemessage
	applymovement (LOCALID_RIVAL1, MeteorFalls_1F_1R_Movement_Rival1ApproachCosmo)
	applymovement (OBJ_EVENT_ID_PLAYER, MeteorFalls_1F_1R_Movement_PlayerApproachCosmo)
	waitmovement (0)
	applymovement (LOCALID_RIVAL1, Common_Movement_BeginTalkDown)
	waitmovement (0)
	rival1talk (MeteorFalls_1F_1R_Text_SpencerWhatHappened,
				MeteorFalls_1F_1R_Text_BrenWhatHappened,
				MeteorFalls_1F_1R_Text_KyleWhatHappened)
	closemessage
	delay (16)
	applymovement (LOCALID_COSMO, Common_Movement_BeginTalkUp)
	waitmovement (0)
	msgbox (MeteorFalls_1F_1R_Text_MeetProfCozmo, MSGBOX_AUTOCLOSE)
	delay (16)
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_FaceRight)
	applymovement (LOCALID_RIVAL1, Common_Movement_BeginTalkLeft)
	waitmovement (0)
	rival1talk (MeteorFalls_1F_1R_Text_SpencerGoingToMtChimney,
				MeteorFalls_1F_1R_Text_BrenGoingToMtChimney,
				MeteorFalls_1F_1R_Text_KyleGoingToMtChimney)
	closemessage
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_FaceUp)
	applymovement (LOCALID_RIVAL1, MeteorFalls_1F_1R_Movement_Rival1Leave)
	waitmovement (0)
	removeobject (LOCALID_RIVAL1)
	return
}

movement MeteorFalls_1F_1R_Movement_Rival1ApproachPlayer {
	walk_down
	walk_in_place_faster_left
}

movement MeteorFalls_1F_1R_Movement_Rival1ApproachCosmo {
	walk_down * 3
	walk_left
	walk_down
}

movement MeteorFalls_1F_1R_Movement_PlayerApproachCosmo {
	delay_8
	walk_right
	walk_down * 3
	walk_left * 2
	walk_down
}

movement MeteorFalls_1F_1R_Movement_Rival1Leave {
	walk_fast_up * 2
	walk_fast_right
	walk_fast_up * 2
	walk_fast_right * 7
}

text MeteorFalls_1F_1R_Text_SpencerShouldCheckOnCosmo {
	format ("We should go check on that guy down there.\p"
		"Who knows what TEAM MAGMA did to him.")
}

text MeteorFalls_1F_1R_Text_BrenShouldCheckOnCosmo {
	format ("We should go check on that guy down there.\p"
		"Who knows what TEAM MAGMA did to him.")
}

text MeteorFalls_1F_1R_Text_KyleShouldCheckOnCosmo {
	format ("We should go check on that guy down there.\p"
