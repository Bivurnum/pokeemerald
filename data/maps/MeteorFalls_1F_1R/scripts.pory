	walk_right
	walk_in_place_faster_up
	step_end

MeteorFalls_1F_1R_Movement_PushPlayerOutOfWay:
	walk_in_place_faster_down
	delay_4
	walk_in_place_faster_right
	lock_facing_direction
	walk_left
	unlock_facing_direction
	face_right
	step_end
`

movement MeteorFalls_1F_1R_Movement_Rival1MoveFromUp {
	walk_left
	walk_down
}

movement MeteorFalls_1F_1R_Movement_PushRival1OutOfWayRight {
	walk_in_place_faster_down
	delay_8 * 2
	lock_facing_direction
	walk_up
	unlock_facing_direction
	face_right
}

movement MeteorFalls_1F_1R_Movement_Rival1GetInPlaceForArchieLeft {
	walk_up
	walk_right * 2
	walk_in_place_faster_down
}

movement MeteorFalls_1F_1R_Movement_Rival1GetInPlaceForArchieRight {
	delay_16
	walk_left
	walk_in_place_faster_down
}

script MeteorFalls_1F_1R_EventScript_Rival1AfterGrunts {
	destroyfollower
	setobjectxyperm (LOCALID_RIVAL1, 14, 17)
	addobject (LOCALID_RIVAL1)
	delay (20)
	applymovement (LOCALID_RIVAL1, MeteorFalls_1F_1R_Movement_Rival1ApproachPlayer)
	waitmovement (0)
	rival1talk (MeteorFalls_1F_1R_Text_SpencerShouldCheckOnCosmo,
				MeteorFalls_1F_1R_Text_BrenShouldCheckOnCosmo,
				MeteorFalls_1F_1R_Text_KyleShouldCheckOnCosmo)
	closemessage
	applymovement (LOCALID_RIVAL1, MeteorFalls_1F_1R_Movement_Rival1ApproachCosmo)
	applymovement (OBJ_EVENT_ID_PLAYER, MeteorFalls_1F_1R_Movement_PlayerApproachCosmo)
	waitmovement (0)
	applymovement (LOCALID_RIVAL1, Common_Movement_BeginTalkDown)
	waitmovement (0)
	rival1talk (MeteorFalls_1F_1R_Text_SpencerWhatHappened,
				MeteorFalls_1F_1R_Text_BrenWhatHappened,
				MeteorFalls_1F_1R_Text_KyleWhatHappened)
	closemessage
	delay (16)
	applymovement (LOCALID_COSMO, Common_Movement_BeginTalkUp)
	waitmovement (0)
	msgbox (MeteorFalls_1F_1R_Text_MeetProfCozmo, MSGBOX_AUTOCLOSE)
	delay (16)
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_FaceRight)
	applymovement (LOCALID_RIVAL1, Common_Movement_BeginTalkLeft)
	waitmovement (0)
	rival1talk (MeteorFalls_1F_1R_Text_SpencerGoingToMtChimney,
				MeteorFalls_1F_1R_Text_BrenGoingToMtChimney,
				MeteorFalls_1F_1R_Text_KyleGoingToMtChimney)
	closemessage
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_FaceUp)
	applymovement (LOCALID_RIVAL1, MeteorFalls_1F_1R_Movement_Rival1Leave)
	waitmovement (0)
	removeobject (LOCALID_RIVAL1)
	return
}

movement MeteorFalls_1F_1R_Movement_Rival1ApproachPlayer {
	walk_down
	walk_in_place_faster_left
}

movement MeteorFalls_1F_1R_Movement_Rival1ApproachCosmo {
	walk_down * 3
	walk_left
	walk_down
}

movement MeteorFalls_1F_1R_Movement_PlayerApproachCosmo {
	delay_8
	walk_right
	walk_down * 3
	walk_left * 2
	walk_down
}

movement MeteorFalls_1F_1R_Movement_Rival1Leave {
	walk_fast_up * 2
	walk_fast_right
	walk_fast_up * 2
	walk_fast_right * 7
}

